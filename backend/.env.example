# Copy this file to ".env" and fill in your own values.
#   cp .env.example .env

# Which AI provider: "openai" (paid, reliable) | "gemini" (free) | "claude"
LLM_PROVIDER=openai

# OpenAI (paid — reliable, no daily caps) — https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# Google Gemini (free) — https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-key-here
GEMINI_MODEL=gemini-2.5-flash-lite

# Anthropic Claude (optional) — https://platform.claude.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# MongoDB Atlas — https://www.mongodb.com/cloud/atlas
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?appName=Cluster0
MONGODB_DB=mumzworld
